#!/usr/bin/env bash
# council — Merlin's Council command center
# Usage: council <command> [args]
#
# Commands:
#   threads              List active threads
#   read <thread_id>     Read a thread's messages
#   inbox [agent]        Check inbox (default: merlin)
#   say <to> <msg>       Send message to agent (or "council" for broadcast)
#   reply <thread> <msg> Reply to a thread
#   agents               Show all agent notification activity
#   recent [n]           Last n messages across all agents (default: 10)
#   search <query>       Search threads and messages
#   decisions            List Council decisions
#   status               System health check
#   help                 Show this help

set -euo pipefail

API="http://localhost:7777"
FROM="merlin"

# Colors
BOLD='\033[1m'
DIM='\033[2m'
CYAN='\033[36m'
GREEN='\033[32m'
YELLOW='\033[33m'
MAGENTA='\033[35m'
RED='\033[31m'
RESET='\033[0m'

cmd="${1:-help}"
shift 2>/dev/null || true

case "$cmd" in

threads)
    n="${1:-3}"
    curl -s "$API/api/threads?status=active&limit=$n" | python3 -c "
import sys, json
d = json.load(sys.stdin)
threads = d.get('threads', [])
print(f'\033[1m{len(threads)} active threads\033[0m (of {d.get(\"total\", \"?\")} total)\n')
for t in threads:
    subj = t.get('subject', '?')[:70]
    parts = ', '.join(t.get('participants', []))
    count = t.get('message_count', 0)
    tid = t.get('id', '?')[:12]
    print(f'\033[36m{tid}\033[0m  [{count}msg] {subj}')
    print(f'          \033[2m{parts}\033[0m')
"
    ;;

read)
    partial="${1:?Usage: council read <thread_id>}"
    # Resolve partial ID to full ID by searching active threads
    tid=$(curl -s "$API/api/threads?status=active&limit=50" | python3 -c "
import sys, json
partial = '$partial'
d = json.load(sys.stdin)
for t in d.get('threads', []):
    if t.get('id', '').startswith(partial):
        print(t['id'])
        break
else:
    # Try all threads if not found in active
    print(partial)
")
    curl -s "$API/api/thread/$tid" | python3 -c "
import sys, json
d = json.load(sys.stdin)
subj = d.get('subject', '?')
print(f'\033[1m{subj}\033[0m\n')
for m in d.get('messages', []):
    fr = m.get('from', '?')
    ts = m.get('timestamp', '')[:19]
    intent = m.get('intent', '')
    color = {'aleph':'\033[32m','luban':'\033[33m','thales':'\033[34m','merlin':'\033[35m','laozi-jung':'\033[36m'}.get(fr, '\033[37m')
    print(f'{color}━━━ {fr} \033[2m{ts} [{intent}]\033[0m')
    print(m.get('content', ''))
    print()
"
    ;;

inbox)
    agent="${1:-merlin}"
    curl -s "$API/api/inbox/$agent?unread_only=false&limit=20" | python3 -c "
import sys, json
d = json.load(sys.stdin)
msgs = d.get('messages', [])
agent = '$agent'
print(f'\033[1m{agent} inbox: {d.get(\"total_count\", len(msgs))} messages\033[0m\n')
for m in msgs[:20]:
    fr = m.get('from', '?')
    subj = m.get('subject', '?')[:60]
    intent = m.get('intent', '')
    ts = m.get('timestamp', '')[:19]
    marker = '\033[31m● \033[0m' if intent == 'request' else '  '
    print(f'{marker}\033[2m{ts}\033[0m  [{fr}] {subj}')
"
    ;;

say)
    to="${1:?Usage: council say <to> <message>}"
    shift
    msg="$*"
    [ -z "$msg" ] && echo "Usage: council say <to> <message>" && exit 1
    # Prompt for subject
    read -p "Subject: " subj
    payload=$(python3 -c "
import json, sys
print(json.dumps({
    'from': sys.argv[1],
    'to': sys.argv[2],
    'subject': sys.argv[3],
    'content': sys.argv[4],
    'intent': 'discuss'
}))
" "$FROM" "$to" "$subj" "$msg")
    curl -s -X POST "$API/api/threads" \
      -H "Content-Type: application/json" \
      -d "$payload" | python3 -c "
import sys, json
d = json.load(sys.stdin)
print(f'\033[32m✓ Message sent\033[0m  Thread: {d.get(\"id\", \"?\")[:12]}')
"
    ;;

reply)
    tid="${1:?Usage: council reply <thread_id> <message>}"
    shift
    msg="$*"
    [ -z "$msg" ] && echo "Usage: council reply <thread_id> <message>" && exit 1
    payload=$(python3 -c "
import json, sys
print(json.dumps({
    'from': sys.argv[1],
    'content': sys.argv[2]
}))
" "$FROM" "$msg")
    curl -s -X POST "$API/api/thread/$tid/reply" \
      -H "Content-Type: application/json" \
      -d "$payload" | python3 -c "
import sys, json
d = json.load(sys.stdin)
print(f'\033[32m✓ Reply sent\033[0m')
"
    ;;

agents)
    echo -e "${BOLD}Council Agent Activity${RESET}\n"
    for agent in aleph luban laozi-jung thales; do
        file="/Users/proteus/astralmaris/ming-qiao/notifications/$agent.jsonl"
        if [ -f "$file" ]; then
            count=$(wc -l < "$file" | tr -d ' ')
            last=$(tail -1 "$file" 2>/dev/null | python3 -c "
import sys,json
try:
    d=json.loads(sys.stdin.read())
    print(f'{d.get(\"timestamp\",\"?\")[:19]}  {d.get(\"subject\",\"?\")[:50]}')
except: print('(empty)')
" 2>/dev/null)
            color=$( [ "$agent" = "aleph" ] && echo "$GREEN" || ( [ "$agent" = "luban" ] && echo "$YELLOW" || ( [ "$agent" = "laozi-jung" ] && echo "$CYAN" || echo "$MAGENTA" ) ) )
            echo -e "  ${color}${agent}${RESET} (${count} notifications)"
            echo -e "    ${DIM}Last: ${last}${RESET}"
        else
            echo -e "  ${DIM}${agent}: no notification file${RESET}"
        fi
    done
    ;;

recent)
    n="${1:-10}"
    echo -e "${BOLD}Last $n Council messages${RESET}\n"
    # Merge all notification files, sort by timestamp, take last n
    cat /Users/proteus/astralmaris/ming-qiao/notifications/*.jsonl 2>/dev/null | \
    python3 -c "
import sys, json
lines = []
for line in sys.stdin:
    line = line.strip()
    if not line: continue
    try:
        d = json.loads(line)
        lines.append(d)
    except: pass
lines.sort(key=lambda x: x.get('timestamp', ''))
n = int('$n')
for d in lines[-n:]:
    fr = d.get('from', '?')
    to = d.get('to', '?')
    ts = d.get('timestamp', '')[:19]
    subj = d.get('subject', '?')[:55]
    intent = d.get('intent', '')
    color = {'aleph':'\033[32m','luban':'\033[33m','thales':'\033[34m','merlin':'\033[35m','laozi-jung':'\033[36m'}.get(fr, '\033[37m')
    marker = '●' if intent == 'request' else '○'
    print(f'{color}{marker} {fr}\033[0m → {to}  \033[2m{ts}\033[0m')
    print(f'  {subj}')
"
    ;;

search)
    q="${1:?Usage: council search <query>}"
    curl -s "$API/api/search?q=$(python3 -c "import urllib.parse; print(urllib.parse.quote('$q'))")&type=all&limit=10" | python3 -c "
import sys, json
d = json.load(sys.stdin)
results = d.get('results', [])
print(f'\033[1m{d.get(\"total\", len(results))} results for \"$q\"\033[0m\n')
for r in results:
    print(f'  \033[36m{r.get(\"id\",\"?\")[:12]}\033[0m  {r.get(\"subject\", r.get(\"content\",\"?\"))[:70]}')
"
    ;;

decisions)
    curl -s "$API/api/decisions?limit=20" | python3 -c "
import sys, json
d = json.load(sys.stdin)
decisions = d.get('decisions', [])
print(f'\033[1m{len(decisions)} Council decisions\033[0m\n')
for dec in decisions:
    status = dec.get('status', '?')
    icon = '✓' if status == 'approved' else '○'
    print(f'  {icon} [{status}] {dec.get(\"title\", dec.get(\"subject\", \"?\"))[:65]}')
" 2>/dev/null || echo -e "${DIM}No decisions endpoint or empty${RESET}"
    ;;

status)
    echo -e "${BOLD}Council Infrastructure Status${RESET}\n"

    # Ming-qiao HTTP
    printf "  Ming-qiao API (:7777)    "
    curl -sf "$API/api/config" >/dev/null 2>&1 && echo -e "${GREEN}HEALTHY${RESET}" || echo -e "${RED}DOWN${RESET}"

    # NATS
    printf "  NATS (:4222)             "
    curl -sf "http://localhost:8222/varz" >/dev/null 2>&1 && echo -e "${GREEN}HEALTHY${RESET}" || echo -e "${YELLOW}NO HTTP MONITOR${RESET}"

    # SurrealDB
    printf "  SurrealDB (:8000)        "
    curl -sf "http://localhost:8000/health" >/dev/null 2>&1 && echo -e "${GREEN}HEALTHY${RESET}" || echo -e "${RED}DOWN${RESET}"

    # Graphiti MCP
    printf "  Graphiti MCP (:8001)     "
    curl -sf "http://localhost:8001/health" >/dev/null 2>&1 && echo -e "${GREEN}HEALTHY${RESET}" || echo -e "${RED}DOWN${RESET}"

    # FalkorDB
    printf "  FalkorDB (:6379)         "
    (redis-cli -p 6379 ping >/dev/null 2>&1 || docker exec $(docker ps -q --filter name=falkor) redis-cli ping >/dev/null 2>&1) && echo -e "${GREEN}HEALTHY${RESET}" || echo -e "${RED}DOWN${RESET}"

    # Ollama
    printf "  Ollama (:11434)          "
    curl -sf "http://localhost:11434/api/tags" >/dev/null 2>&1 && echo -e "${GREEN}HEALTHY${RESET}" || echo -e "${RED}DOWN${RESET}"

    # Merlin UI
    printf "  Merlin UI (:5173)        "
    curl -sf "http://localhost:5173" >/dev/null 2>&1 && echo -e "${GREEN}HEALTHY${RESET}" || echo -e "${RED}DOWN${RESET}"

    echo ""
    echo -e "${BOLD}Ollama Models${RESET}"
    ollama list 2>/dev/null | head -10 || echo "  (ollama not in PATH)"

    echo ""
    echo -e "${BOLD}Docker Containers${RESET}"
    docker ps --format "  {{.Names}}\t{{.Status}}\t{{.Ports}}" 2>/dev/null | head -10 || echo "  (docker not available)"
    ;;

help|*)
    echo -e "${BOLD}council${RESET} — Merlin's Council command center\n"
    echo -e "${BOLD}Commands:${RESET}"
    echo -e "  ${CYAN}council threads${RESET} [n]            List active threads (default: 20)"
    echo -e "  ${CYAN}council read${RESET} <thread_id>     Read a thread"
    echo -e "  ${CYAN}council inbox${RESET} [agent]        Check inbox (default: merlin)"
    echo -e "  ${CYAN}council say${RESET} <to> <message>   Send a message"
    echo -e "  ${CYAN}council reply${RESET} <tid> <msg>    Reply to thread"
    echo -e "  ${CYAN}council agents${RESET}               Agent notification activity"
    echo -e "  ${CYAN}council recent${RESET} [n]           Last n cross-agent messages"
    echo -e "  ${CYAN}council search${RESET} <query>       Search threads and messages"
    echo -e "  ${CYAN}council decisions${RESET}            List Council decisions"
    echo -e "  ${CYAN}council status${RESET}               Infrastructure health check"
    echo ""
    echo -e "${BOLD}Examples:${RESET}"
    echo ""
    echo -e "  ${DIM}# Quick glance at latest 3 threads${RESET}"
    echo -e "  council threads 3"
    echo ""
    echo -e "  ${DIM}# Morning check-in — see what happened overnight${RESET}"
    echo -e "  council agents"
    echo -e "  council recent 15"
    echo ""
    echo -e "  ${DIM}# Read Aleph's ORACLE infrastructure report${RESET}"
    echo -e "  council threads"
    echo -e "  council read 019cb424-e53e   ${DIM}# use first 12 chars of thread ID${RESET}"
    echo ""
    echo -e "  ${DIM}# Check what Luban has been up to${RESET}"
    echo -e "  council inbox luban"
    echo ""
    echo -e "  ${DIM}# Send Aleph a direct message${RESET}"
    echo -e "  council say aleph 'Please review the ontology seed data before ingestion'"
    echo ""
    echo -e "  ${DIM}# Broadcast a decision to the whole Council${RESET}"
    echo -e "  council say council 'DECISION: We will ingest the Gmail backlog in batches of 20'"
    echo ""
    echo -e "  ${DIM}# Reply to an existing thread${RESET}"
    echo -e "  council reply 019cb424-e53e 'Acknowledged. Good work on the port fix.'"
    echo ""
    echo -e "  ${DIM}# Find past discussions about adapters${RESET}"
    echo -e "  council search adapters"
    echo ""
    echo -e "  ${DIM}# Full infrastructure health check${RESET}"
    echo -e "  council status"
    ;;
esac
